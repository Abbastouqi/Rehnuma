# ── Core ──────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database (SQLite) ─────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./gemma_chat.db

# ── LLM Model ────────────────────────────────────────────────
MODEL_URL=https://rahnuma.riphah.edu.pk
MODEL_NAME=unsloth/Qwen3-4B-Instruct-2507-GGUF:Q4_K_M
MAX_TOKENS=2048

# ── MongoDB (user profiles, login history, API keys) ──────────
# Install MongoDB: https://www.mongodb.com/try/download/community
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=rahnuma

# ── Email (SMTP) ──────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at
#   https://myaccount.google.com/apppasswords
# For university SMTP: use your IT-provided credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_NAME=Rahnuma — Riphah International University

# ── App URL (used in verification/reset email links) ──────────
APP_URL=http://localhost:5173

# ── ChromaDB Vector Memory ────────────────────────────────────
# Run: pip install chromadb
# First startup downloads ~80 MB ONNX model automatically
CHROMA_PATH=./data/chroma
